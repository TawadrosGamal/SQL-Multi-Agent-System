OPENAI_API_KEY=sk-your-openai-api-key-here

# Database presets -- any env var matching DB_*=<url> becomes a selectable
# preset in the Streamlit sidebar.  The label is derived from the suffix
# (e.g. DB_SQLITE -> "Sqlite", DB_MYSQL -> "Mysql").
DB_SQLITE=sqlite:///retail_orders.db
DB_MYSQL=mysql+pymysql://root:yourpassword@localhost:3306/retail_orders

# Legacy single-URL form (still works, used as initial active DB):
# DATABASE_URL=sqlite:///retail_orders.db

MODEL_NAME=gpt-4o-mini
